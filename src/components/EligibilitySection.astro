---
import { assets } from "../data/assets";
---

<section class="mx-auto mt-24 max-w-[1240px] px-6" data-animate-group>
  <div class="grid items-center gap-12 lg:grid-cols-[1fr_1fr]">
    <div class="relative lg:justify-self-start" data-animate>
      <div class="absolute right-12 bottom-[-18px] h-[98%] w-[74%] rounded-[14px] bg-[#f4d9d9]"></div>
      <div class="relative aspect-[3/4] w-[86%] overflow-hidden rounded-[12px]">
        <img
          src={assets.eligibilityImage}
          alt="Kenyan landscape"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
    <div class="flex flex-col gap-5" data-animate>
      <h2 class="text-[34px] font-semibold text-[#a0152a] md:text-[40px]">
        Who should apply?
      </h2>
      <p class="text-[18px] text-[#666]">
        If you've been waiting for a sign... this is it.
      </p>
      <ul class="space-y-3 pl-6 text-[17px] text-[#7a7a7a]">
        <li class="list-disc">You are a young person based in Kenya, aged 15-25</li>
        <li class="list-disc">
          You have an idea, project, or early-stage venture you want to develop
        </li>
        <li class="list-disc">You are enrolled in school or recently graduated</li>
        <li class="list-disc">
          You are ready to commit to the program structure and weekly
          accountability process
        </li>
        <li class="list-disc">
          You want to solve a real problem in your community using technology,
          entrepreneurship, or both
        </li>
      </ul>
    </div>
  </div>
</section>
