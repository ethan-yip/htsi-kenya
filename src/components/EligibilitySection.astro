---
import { assets } from "../data/assets";
---

<section class="mx-auto mt-16 max-w-[1240px] px-6 sm:mt-24" data-animate-group>
  <div class="grid items-center gap-10 lg:grid-cols-[1fr_1fr]">
    <div class="relative lg:justify-self-start" data-animate>
      <div class="absolute right-6 bottom-[-12px] h-[92%] w-[74%] rounded-[14px] bg-[#f4d9d9] sm:right-12 sm:bottom-[-18px] sm:h-[98%]"></div>
      <div class="relative aspect-[3/4] w-full overflow-hidden rounded-[12px] sm:w-[86%]">
        <img
          src={assets.eligibilityImage}
          alt="Kenyan landscape"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
    <div class="flex flex-col gap-4 sm:gap-5" data-animate>
      <h2 class="text-[26px] font-semibold text-[#a0152a] sm:text-[32px] md:text-[40px]">
        Who should apply?
      </h2>
      <p class="text-[16px] text-[#666] sm:text-[18px]">
        If you've been waiting for a sign... this is it.
      </p>
      <ul class="space-y-3 pl-5 text-[15px] text-[#7a7a7a] sm:pl-6 sm:text-[17px]">
        <li class="list-disc">You are a young person based in Kenya, aged 15-25</li>
        <li class="list-disc">
          You have an idea, project, or early-stage venture you want to develop
        </li>
        <li class="list-disc">You are enrolled in school or recently graduated</li>
        <li class="list-disc">
          You are ready to commit to the program structure and weekly
          accountability process
        </li>
        <li class="list-disc">
          You want to solve a real problem in your community using technology,
          entrepreneurship, or both
        </li>
      </ul>
    </div>
  </div>
</section>
