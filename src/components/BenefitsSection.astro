---
import { assets } from "../data/assets";

const benefits = [
  {
    title: "Financial Support",
    icon: assets.icons.creditCard,
    detail:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam vitae justo ut libero gravida gravida.",
  },
  {
    title: "Global Network",
    icon: assets.icons.globe,
    detail:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut tincidunt arcu sed lorem varius, vel tempus nulla posuere.",
  },
  {
    title: "Technology & Infrastructure",
    icon: assets.icons.laptop,
    detail:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed at massa id odio tincidunt egestas.",
  },
  {
    title: "Mentorship & Guidance",
    icon: assets.icons.member,
    detail:
      "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Aenean euismod, nunc sit amet tempus cursus, sapien sem.",
  },
];
---

<section class="mx-auto mt-20 max-w-[1240px] px-6" data-animate-group>
  <div class="flex flex-wrap items-end justify-between gap-6" data-animate>
    <div>
      <h2 class="text-[36px] font-semibold text-[#a0152a] md:text-[40px]">
        See what you get
      </h2>
      <p class="mt-2 text-[16px] text-[#a9a9a9]">Hover to see more</p>
    </div>
  </div>
  <div class="mt-8 grid gap-6 md:grid-cols-2" data-animate-group data-animate>
    {benefits.map((benefit) => (
      <div
        class="benefit-card group relative flex h-full cursor-pointer flex-col gap-6 rounded-[32px] p-8 text-[#800000] transition-colors duration-300"
        data-animate
      >
        <div class="flex flex-col gap-5 transition-opacity duration-300 group-hover:opacity-0">
          <div class="flex h-14 w-14 items-center justify-center">
            <img src={benefit.icon} alt="" class="h-full w-full" />
          </div>
          <p class="text-[24px] font-semibold md:text-[28px]">
            {benefit.title}
          </p>
        </div>
        <p class="benefit-detail pointer-events-none absolute inset-0 flex items-center px-8 text-[18px] leading-[1.6] opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          {benefit.detail}
        </p>
      </div>
    ))}
  </div>
</section>

<style>
  .benefit-card {
    background-color: #ffe6e6;
  }

  .benefit-card:hover {
    background-color: #800000;
    color: #ffffff;
  }

  .benefit-card:hover .benefit-detail {
    color: #ffffff;
  }
</style>
