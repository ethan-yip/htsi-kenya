---
import { assets } from "../data/assets";

const benefits = [
  {
    title: "Financial Support",
    icon: assets.icons.creditCard,
    detail:
      "Undilutive cash grants funded directly by HTSI or our partner organizations. Average grants of KES 40,000+ with potential awards up to KES 129,000. No equity taken. No strings.",
  },
  {
    title: "Global Network",
    icon: assets.icons.globe,
    detail:
      "Connection to organizations across the United States, Europe, and Asia — and access to the UN network. Top participants may be invited to pitch at the HTSI Global Demo Day, with potential exposure at the UN General Assembly 81st Session.",
  },
  {
    title: "Technology & Infrastructure",
    icon: assets.icons.laptop,
    detail:
      "Access to hardware (microcontrollers, chips, circuit design resources) and software infrastructure (cloud compute, AI tool subscriptions, API credits) provided by HTSI and our technology partners.",
  },
  {
    title: "Mentorship & Guidance",
    icon: assets.icons.member,
    detail:
      "Remote mentorship sessions via Zoom with HTSI advisors, staff, and a global network of guest mentors — including YC-backed founders, FAANG engineers, Yale faculty, and leading venture capitalists managing funds over $250M AUM.",
  },
];
---

<section
  class="mx-auto mt-16 max-w-[1240px] scroll-mt-[120px] px-6 sm:mt-20"
  id="benefits"
  data-animate-group
>
  <div class="flex flex-wrap items-end justify-between gap-6" data-animate>
    <div>
      <h2 class="text-[28px] font-semibold text-[#a0152a] sm:text-[32px] md:text-[40px]">
        See what you get
      </h2>
      <p
        class="mt-2 text-[14px] text-[#a9a9a9] sm:text-[16px]"
        data-benefit-helper
      >
        Hover to see more
      </p>
    </div>
  </div>
  <div class="mt-6 grid gap-6 md:grid-cols-2" data-animate-group data-animate>
    {benefits.map((benefit) => (
      <div
        class="benefit-card group relative flex h-full cursor-pointer flex-col gap-6 rounded-[32px] p-8 text-[#800000]"
        data-animate
        data-benefit-card
      >
        <div class="flex flex-col gap-5" data-benefit-front>
          <div class="flex h-14 w-14 items-center justify-center" data-benefit-icon>
            <img src={benefit.icon} alt="" class="h-full w-full" />
          </div>
          <p class="text-[24px] font-semibold md:text-[28px]">
            {benefit.title}
          </p>
        </div>
        <p
          class="benefit-detail pointer-events-none absolute inset-0 flex items-center px-8 text-[14px] sm:text-[18px] leading-[1.6]"
          data-benefit-detail
        >
          {benefit.detail}
        </p>
      </div>
    ))}
  </div>
</section>

<script>
  import { gsap } from "gsap";

  document.addEventListener("DOMContentLoaded", () => {
    const cards = Array.from(
      document.querySelectorAll("[data-benefit-card]")
    ) as HTMLElement[];
    const helper = document.querySelector("[data-benefit-helper]");

    if (helper) {
      const updateHelper = () => {
        helper.textContent = window.matchMedia("(max-width: 640px)").matches
          ? "Click to see more"
          : "Hover to see more";
      };

      updateHelper();
      window.addEventListener("resize", updateHelper);
    }

    cards.forEach((card) => {
      const front = card.querySelector("[data-benefit-front]");
      const detail = card.querySelector("[data-benefit-detail]");
      const icon = card.querySelector("[data-benefit-icon]");

      if (!front || !detail || !icon) {
        return;
      }

      gsap.set(detail, { opacity: 0, y: 18 });
      gsap.set(icon, { y: 0 });

      const hoverIn = () => {
        card.classList.add("is-active");
        gsap.killTweensOf([front, detail, icon, card]);
        gsap.to(card, {
          backgroundColor: "#800000",
          color: "#ffffff",
          duration: 0.35,
          ease: "power2.out",
        });
        gsap.to(front, {
          opacity: 0,
          y: -12,
          duration: 0.3,
          ease: "power2.out",
        });
        gsap.to(icon, {
          y: -16,
          duration: 0.45,
          ease: "expo.out",
        });
        gsap.to(detail, {
          opacity: 1,
          y: 0,
          duration: 0.5,
          ease: "expo.out",
        });
      };

      const hoverOut = () => {
        card.classList.remove("is-active");
        gsap.killTweensOf([front, detail, icon, card]);
        gsap.to(card, {
          backgroundColor: "#ffe6e6",
          color: "#800000",
          duration: 0.3,
          ease: "power2.out",
        });
        gsap.to(front, {
          opacity: 1,
          y: 0,
          duration: 0.25,
          ease: "power2.out",
        });
        gsap.to(icon, {
          y: 0,
          duration: 0.3,
          ease: "power2.out",
        });
        gsap.to(detail, {
          opacity: 0,
          y: 18,
          duration: 0.25,
          ease: "power2.out",
        });
      };

      const toggleActive = () => {
        const isActive = card.classList.contains("is-active");

        cards.forEach((other) => {
          if (other !== card) {
            other.classList.remove("is-active");
          }
        });

        if (isActive) {
          hoverOut();
        } else {
          hoverIn();
        }
      };

      card.addEventListener("mouseenter", hoverIn);
      card.addEventListener("mouseleave", hoverOut);
      card.addEventListener("click", toggleActive);
    });
  });
</script>

<style>
  .benefit-card {
    background-color: #ffe6e6;
  }

  .benefit-detail {
    color: #ffffff;
  }

  .benefit-card.is-active .benefit-detail {
    opacity: 1;
    transform: translateY(0);
  }

  .benefit-card.is-active [data-benefit-front] {
    opacity: 0;
    transform: translateY(-12px);
  }
</style>
