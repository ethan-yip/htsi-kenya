---
import { assets } from "../data/assets";
---

<header class="sticky top-0 z-30 bg-white/95 backdrop-blur">
  <nav
    class="mx-auto flex w-full items-center justify-between px-32 py-6"
  >
    <div class="flex items-center gap-4" data-animate-group>
      <div class="flex items-center gap-3" data-animate>
        <span
          class="font-serif text-[40px] font-bold leading-none text-[#a0152a]"
          >HTSI</span
        >
        <span class="text-[26px] leading-none text-[#353535]">
          Kenya Open Call
        </span>
      </div>
    </div>
    <div class="hidden items-center gap-10 text-[18px] md:flex" data-animate>
      <div class="relative flex items-center">
        <button class="leading-none text-[#a0152a]">About</button>
        <span
          class="absolute left-1/2 top-[calc(100%+10px)] h-[2px] bg-[#800000] w-16 -translate-x-1/2"
        />
      </div>
      <button class="leading-none text-black">What You Get</button>
      <button class="leading-none text-black">How to Apply</button>
      <button class="leading-none text-black">FAQ</button>
      <button
        class="rounded-[10px] bg-[#800000] px-5 py-2 text-[16px] text-white"
      >
        Apply Now
      </button>
    </div>
  </nav>
</header>
