---
const faqs = [
  {
    question: "Is this program free to apply to?",
    answer:
      "Yes. There is no cost to apply and no cost to participate. All funding provided through the program is undilutive — HTSI does not take equity in your project.",
  },
  {
    question: "Do I need to already have a startup or company?",
    answer:
      "No. You do not need a finished product or existing company. If you have an idea and the drive to develop it, we want to hear from you.",
  },
  {
    question: "What is the time commitment?",
    answer:
      "Participants should expect to commit time weekly for mentorship sessions, milestone check-ins, and project development. Specific hours will be confirmed at the cohort onboarding stage.",
  },
  {
    question: "I am outside Nairobi. Can I still apply?",
    answer:
      "Yes. While the program has on-the-ground partners in Nairobi, remote participation is supported. We encourage applicants from across Kenya.",
  },
  {
    question: "What kinds of projects are eligible?",
    answer:
      "Technology-oriented projects with a focus on solving real problems in your community. This includes software, hardware, social ventures, and applied AI projects. If you are unsure whether your idea qualifies, apply and explain your thinking.",
  },
  {
    question: "What does 'undilutive funding' mean?",
    answer:
      "It means HTSI grants you money without taking any ownership or equity in your project in return. The funding is yours to use for your project.",
  },
  {
    question: "Can I apply if I have already received funding elsewhere?",
    answer:
      "Yes. Prior funding does not disqualify you. Describe your project's current stage honestly in the application.",
  },
  {
    question: "When will I hear back after applying?",
    answer:
      "We aim to respond to all applicants within <X> weeks of the application deadline. Shortlisted candidates will be contacted for an interview.",
  },
];
---

<section
  class="mx-auto mt-20 max-w-[1100px] scroll-mt-[120px] px-6 text-center"
  id="faq"
  data-animate-group
>
  <p class="text-[14px] uppercase tracking-[0.3em] text-[#a0152a]" data-animate>
    FAQ
  </p>
  <h2 class="mt-3 text-[32px] font-semibold text-[#212121] sm:text-[40px] md:text-[48px]" data-animate>
    Frequently Asked Questions
  </h2>

  <div class="mt-10 space-y-4 text-left" data-animate-group>
    {faqs.map((item) => (
      <details class="faq-item rounded-[24px] bg-[#f4f5f7] px-6 py-5" data-animate>
        <summary class="faq-summary flex cursor-pointer items-center justify-between gap-4 text-[16px] font-semibold text-[#212121] sm:text-[18px]">
          {item.question}
          <span class="faq-icon flex h-8 w-8 items-center justify-center rounded-full bg-white text-[#8b8b8b]">+</span>
        </summary>
        <div class="faq-answer">
          <p class="mt-4 text-[15px] leading-[1.6] text-[#5f5f5f] sm:text-[16px]">
            {item.answer}
          </p>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  details.faq-item > summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary {
    transition: color 200ms ease;
  }

  details.faq-item:hover .faq-summary {
    color: #800000;
  }

  .faq-answer {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 260ms ease, opacity 220ms ease;
  }

  details.faq-item[open] .faq-answer {
    max-height: 220px;
    opacity: 1;
  }

  details.faq-item[open] .faq-icon {
    transform: rotate(45deg);
  }
</style>
