---
import { assets } from "../data/assets";
---

<section class="mx-auto mt-4 max-w-full px-4 sm:px-6 lg:px-10 overflow-hidden" data-animate-group>
  <div
    class="relative grid gap-10 rounded-[32px] bg-[#800000] p-6 sm:p-8 lg:min-h-[820px] lg:rounded-[42px] lg:p-20 lg:max-w-[80vw]"
  >
    <div class="flex flex-col justify-center gap-6 lg:pr-4 lg:max-w-[46vw] 2xl:max-w-[43vw]">
      <p class="text-[16px] tracking-[0.2em] text-white/80" data-animate>
        HTSI AFRICAN DEVELOPMENT AND GROWTH FUND
      </p>
      <h1
        class="font-serif text-[40px] font-bold leading-[1.05] tracking-tight text-white sm:text-[48px] md:text-[56px] lg:text-[6vw] 2xl:text-[5vw]"
        data-animate
      >
        <span>Your idea </span>
        <span class="font-serif font-normal italic">deserves</span>
        <span> to exist in the real world.</span>
      </h1>
      <p class="text-[16px] leading-[1.5] text-[#d3baba] sm:text-[18px] lg:text-[20px]" data-animate>
        We're looking for the next generation of Kenyan innovators - builders,
        problem-solvers, and founders who are ready to turn ideas into real
        impact.
      </p>
      <a
        class="group mt-2 inline-flex w-fit cursor-pointer items-center gap-3 rounded-[42px] bg-white px-6 py-3 text-[16px] font-semibold text-[#a0152a] transition-colors duration-300 hover:bg-[#a0152a] hover:text-white sm:mt-4 sm:px-8 sm:py-4 sm:text-[18px]"
        data-animate
        href="https://docs.google.com/forms/d/e/1FAIpQLSftK2x12nYn21MvqgHudHurYCPIaCGQUcyH-QB9t44JXMdtaQ/viewform?usp=publish-editor"
      >
        Apply to the KDP
        <img
          src={assets.icons.arrowRight}
          alt=""
          class="h-5 w-5 transition duration-300 group-hover:brightness-0 group-hover:invert"
        />
      </a>
    </div>
  </div>
  <div
    class="hero-image-wrap relative mt-8 lg:absolute lg:top-[20vh] 2xl:top-[30vh] lg:right-[-28px] lg:w-[45%]"
    data-animate
  >
    <div class="hero-image relative aspect-[121/182] w-full overflow-hidden rounded-[36px] shadow-[0_28px_60px_rgba(0,0,0,0.25)]">
      <img
        src={assets.heroImage}
        alt="Smiling founder in Nairobi"
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  @media (min-width: 1536px) {
    .hero-image {
      aspect-ratio: 4 / 3;
    }

    .hero-image-wrap {
      width: 50%;
    }
  }
</style>
