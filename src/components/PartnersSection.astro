---
import { assets } from "../data/assets";

const logos = [
  assets.partners.frame,
  assets.partners.image1,
  assets.partners.image2,
  assets.partners.image3,
  assets.partners.image4,
  assets.partners.layer1,
];
---

<section class="mx-auto mt-24 max-w-[1240px] px-6 text-center" data-animate-group>
  <h2 class="mt-8 text-[48px] text-[#212121] md:text-[64px]" data-animate>
    <span>Supported by </span>
    <span class="font-serif font-bold italic">many</span>
    <span> partners</span>
  </h2>
  <div
    class="mt-12 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3"
    data-animate
  >
    {logos.map((logo) => (
      <div class="flex items-center justify-center">
        <img src={logo} alt="" class="max-h-28 w-auto" loading="lazy" />
      </div>
    ))}
  </div>
  <p class="mt-10 text-[28px] text-[#212121] md:text-[36px]" data-animate>
    ...and backed by just as much prestige.
  </p>
</section>
